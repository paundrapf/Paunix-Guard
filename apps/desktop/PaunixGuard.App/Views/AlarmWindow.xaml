<Window x:Class="PaunixGuard.App.Views.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paunix Guard Alarm"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#B42318">
  <Grid Margin="48">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="720">
      <TextBlock Text="PAUNIX GUARD"
                 Foreground="#FFE7E5"
                 FontSize="18"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="ALARM ACTIVE"
                 Foreground="White"
                 FontSize="72"
                 FontWeight="Bold"
                 TextAlignment="Center"
                 Margin="0,12,0,8" />
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="#FFE7E5"
                 FontSize="20"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 Margin="0,0,0,28" />

      <PasswordBox x:Name="AlarmPinBox"
                   Width="320"
                   PasswordChanged="AlarmPinBox_OnPasswordChanged" />
      <Button Content="Stop Alarm"
              Command="{Binding DisarmCommand}"
              Width="180"
              Margin="0,16,0,0" />
    </StackPanel>
  </Grid>
</Window>

