<Window x:Class="PaunixGuard.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event History"
        Width="700"
        Height="450"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
      <TextBlock Text="Event History"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="#15191F" />
      <Button Content="Refresh"
              Click="Refresh_Click"
              Width="80"
              HorizontalAlignment="Right"
              Margin="16,0,0,0" />
    </StackPanel>

    <Border Grid.Row="1"
            Background="White"
            BorderBrush="#D9DEE7"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12">
      <ListView x:Name="EventsList"
                BorderThickness="0">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Time" Width="160" DisplayMemberBinding="{Binding CreatedAt}" />
            <GridViewColumn Header="Trigger" Width="140" DisplayMemberBinding="{Binding TriggerType}" />
            <GridViewColumn Header="Resolution" Width="100" DisplayMemberBinding="{Binding Resolution}" />
            <GridViewColumn Header="Reason" Width="260" DisplayMemberBinding="{Binding Reason}" />
          </GridView>
        </ListView.View>
      </ListView>
    </Border>

    <TextBlock Grid.Row="2"
               Text="Events are stored locally under %LocalAppData%\\PaunixGuard."
               Foreground="#56606D"
               Margin="0,12,0,0" />
  </Grid>
</Window>
