<Window x:Class="PaunixGuard.App.Views.GuardScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paunix Guard - Armed"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#1A1D23"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Opacity="0.96">
  <Grid Margin="48">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="720">
      <TextBlock Text="PAUNIX GUARD"
                 Foreground="#6A728A"
                 FontSize="18"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="ARMED"
                 Foreground="#38B249"
                 FontSize="72"
                 FontWeight="Bold"
                 TextAlignment="Center"
                 Margin="0,12,0,8" />
      <TextBlock Text="Your laptop is protected. Alarm will sound if someone touches it."
                 Foreground="#9BA3B5"
                 FontSize="18"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 Margin="0,0,0,32" />

      <PasswordBox x:Name="GuardPinBox"
                   Width="320"
                   PasswordChanged="GuardPinBox_OnPasswordChanged"
                   Background="#2A2D35"
                   Foreground="White"
                   CaretBrush="White"
                   BorderBrush="#3E4652" />
      <Button Content="Disarm"
              Command="{Binding DisarmCommand}"
              Width="180"
              Height="40"
              Margin="0,12,0,0"
              Background="#38B249"
              Foreground="White"
              FontWeight="SemiBold" />
    </StackPanel>
  </Grid>
</Window>
