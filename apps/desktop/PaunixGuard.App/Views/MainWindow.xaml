<Window x:Class="PaunixGuard.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paunix Guard"
        MinWidth="640"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9"
        FontFamily="Segoe UI">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal">
      <Image Source="/Assets/logo.png"
             Width="36"
             Height="36"
             Margin="0,0,12,0" />
      <StackPanel>
        <TextBlock Text="Paunix Guard"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="#15191F" />
        <TextBlock Text="Offline-first laptop guard for short public-space breaks."
                   FontSize="13"
                   Foreground="#56606D"
                   Margin="0,2,0,20" />
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="1.2*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="White"
              BorderBrush="#D9DEE7"
              BorderThickness="1"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="Status"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#56606D" />
          <TextBlock Text="{Binding CurrentState}"
                     FontSize="42"
                     FontWeight="Bold"
                     Foreground="#0D1117"
                     Margin="0,8,0,8" />
          <TextBlock Text="{Binding StatusMessage}"
                     TextWrapping="Wrap"
                     Foreground="#3E4652"
                     MinHeight="48" />

          <Separator Margin="0,18,0,18" />

          <TextBlock Text="PIN"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#56606D" />
          <PasswordBox x:Name="PinBox"
                       PasswordChanged="PinBox_OnPasswordChanged"
                       Margin="0,8,0,8" />
          <WrapPanel>
            <Button Content="Save PIN"
                    Command="{Binding SavePinCommand}" />
            <Button Content="Start Guard"
                    Command="{Binding StartGuardCommand}" />
            <Button Content="Disarm"
                    Command="{Binding DisarmCommand}" />
          </WrapPanel>

          <WrapPanel Margin="0,16,0,0">
            <Button Content="Test Alarm"
                    Command="{Binding TestAlarmCommand}" />
            <Button Content="Check Updates"
                    Command="{Binding CheckUpdatesCommand}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Background="White"
              BorderBrush="#D9DEE7"
              BorderThickness="1"
              CornerRadius="8"
              Padding="20">
        <StackPanel>
          <TextBlock Text="Protection"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#56606D" />
          <TextBlock Text="Enabled by default"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Margin="0,8,0,16" />
          <TextBlock Text="- Charger unplug"
                     Margin="0,0,0,8" />
          <TextBlock Text="- Keyboard/mouse activity"
                     Margin="0,0,0,8" />
          <TextBlock Text="- Sleep attempt"
                     Margin="0,0,0,8" />
          <TextBlock Text="- Shutdown/logoff attempt"
                     Margin="0,0,0,18" />

          <Separator Margin="0,0,0,18" />

          <TextBlock Text="Latest event"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#56606D" />
          <TextBlock Text="{Binding LatestEvent}"
                     TextWrapping="Wrap"
                     Margin="0,8,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2">
      <WrapPanel Margin="0,0,0,8">
        <Button Content="Settings" Click="Settings_Click" Width="80" />
        <Button Content="History" Click="History_Click" Width="80" />
        <Button Content="Reset PIN" Click="ResetPin_Click" Width="90" />
      </WrapPanel>
      <TextBlock Text="Paunix Guard does not record keys, read files, read clipboard data, or run hidden monitoring."
                 Foreground="#56606D"
                 FontSize="11" />
    </StackPanel>
  </Grid>
  </ScrollViewer>
</Window>
