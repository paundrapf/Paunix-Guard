<Window x:Class="PaunixGuard.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="560"
        Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9"
        ResizeMode="NoResize">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Paunix Guard Settings"
               FontSize="20"
               FontWeight="SemiBold"
               Foreground="#15191F"
               Margin="0,0,0,16" />

    <TabControl Grid.Row="1">
      <TabItem Header="Triggers">
        <StackPanel Margin="16">
          <CheckBox x:Name="ChkCharger" IsChecked="True" Margin="0,0,0,10">
            Charger unplugged trigger
          </CheckBox>
          <CheckBox x:Name="ChkInput" IsChecked="True" Margin="0,0,0,10">
            Keyboard / mouse / trackpad input trigger
          </CheckBox>
          <CheckBox x:Name="ChkLidClose" IsChecked="True" Margin="0,0,0,10">
            Lid closed trigger
          </CheckBox>
          <CheckBox x:Name="ChkSleep" IsChecked="True" Margin="0,0,0,10">
            Sleep attempt trigger
          </CheckBox>
          <CheckBox x:Name="ChkShutdown" IsChecked="True">
            Shutdown / logoff attempt trigger
          </CheckBox>
        </StackPanel>
      </TabItem>
      <TabItem Header="Alarm">
        <StackPanel Margin="16">
          <CheckBox x:Name="ChkForceVolume" IsChecked="True" Margin="0,0,0,12">
            Force max volume on alarm
          </CheckBox>
          <CheckBox x:Name="ChkRestoreAudio" IsChecked="True" Margin="0,0,0,12">
            Restore audio state after disarm
          </CheckBox>
          <TextBlock Text="Arming delay (seconds)" FontSize="13" Foreground="#3E4652" Margin="0,0,0,4" />
          <TextBox x:Name="TxtArmingDelay" Text="5" Width="80" HorizontalAlignment="Left" Margin="0,0,0,16" />
          <TextBlock Text="Alarm sound path (optional)" FontSize="13" Foreground="#3E4652" Margin="0,0,0,4" />
          <TextBox x:Name="TxtAlarmSound" Width="400" HorizontalAlignment="Left" />
        </StackPanel>
      </TabItem>
      <TabItem Header="Power">
        <StackPanel Margin="16">
          <CheckBox x:Name="ChkKeepAwake" IsChecked="True" Margin="0,0,0,12">
            Keep laptop awake while armed
          </CheckBox>
          <CheckBox x:Name="ChkBlockShutdown" IsChecked="True">
            Block normal shutdown while armed
          </CheckBox>
        </StackPanel>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Save" Click="Save_Click" Width="80" />
      <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>
