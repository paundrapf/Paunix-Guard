---
const links = [
  ["Download", "/download"],
  ["Security", "/security"],
  ["Docs", "/docs"],
  ["Changelog", "/changelog"],
  ["FAQ", "/faq"],
  ["Support", "/support"]
];
---

<header class="nav">
  <div class="page-shell nav-inner">
    <a class="brand" href="/" aria-label="Paunix Guard home">
      <img src="/brand/logo-128x128.png" alt="" width="34" height="34" />
      <span>Paunix Guard</span>
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {links.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
    <div class="nav-actions">
      <a class="icon-btn" href="https://github.com/paundrapf/Paunix-Guard" aria-label="Open Paunix Guard on GitHub" title="GitHub repository">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M12.01 2C6.48 2 2 6.59 2 12.25c0 4.52 2.87 8.36 6.84 9.72.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1.01.07 1.54 1.06 1.54 1.06.9 1.57 2.36 1.11 2.94.85.09-.67.35-1.11.64-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.04-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.76 1.05A9.36 9.36 0 0 1 12 6.99c.85 0 1.7.12 2.5.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.65.72 1.04 1.63 1.04 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.15 10.15 0 0 0 22 12.25C22 6.59 17.53 2 12.01 2Z" />
        </svg>
      </a>
      <a class="btn btn-primary" href="/download/windows">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Download
      </a>
    </div>
  </div>
</header>
